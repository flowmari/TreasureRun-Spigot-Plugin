package plugin;

import org.bukkit.Bukkit;
import org.bukkit.Color;
import org.bukkit.Location;
import org.bukkit.Particle;
import org.bukkit.Sound;
import org.bukkit.World;
import org.bukkit.block.Block; // ✅ 追加（足元ブロック操作に必要）
import org.bukkit.block.data.BlockData;
import org.bukkit.entity.Entity;
import org.bukkit.entity.LivingEntity;
import org.bukkit.entity.Player;
import org.bukkit.entity.TraderLlama;
import org.bukkit.entity.WanderingTrader;
import org.bukkit.inventory.ItemStack;
import org.bukkit.Material;
import org.bukkit.plugin.java.JavaPlugin;
import org.bukkit.potion.PotionEffect;
import org.bukkit.potion.PotionEffectType;
import org.bukkit.scheduler.BukkitRunnable;

import java.util.*;

/**
 * ✅ 商人の周囲3マス：アンバーのリング（動くセーフゾーン）
 * ✅ 商人の歩いた跡：数秒だけ残光（アンバーの軌跡）
 * ✅ プレイヤーが離れると世界が冷える（霧/音）
 *
 * ✅ 追加（完全版）
 * ✅ 商人＋ラマ両方がセーフゾーンキャリア（隊商）
 * ✅ セーフゾーン内：クラックが鎮まる
 * ✅ セーフゾーン外：クラックが増える（ヘアライン→幾何学）
 * ✅ 宝箱接近：クラックがピーク＆音も同期（不安×興奮）
 *
 * ✅ 追加（物理的に刺す強化）
 * ✅ 宝箱2m以内：ガラス破片（粒）が“放散”する（散りゆく光）
 * ✅ 宝箱2m以内：0.5秒だけ視界が微妙に揺れる（疑似屈折）
 *
 * ✅ 追加（数学的な幾何学クラック）
 * ✅ 宝箱2m以内：2重リング（内側＋外側）
 * ✅ 角度固定（60度刻み/45度刻み）
 * ✅ 割れ筋の方向性（放射状ライン）
 *
 * ✅ 互換条件
 * ❌ Bukkit.getCurrentTick() を使わない
 * ❌ World.getEntity(UUID) を使わない
 * ✅ Spigot 1.20.1 でコンパイルが通る
 *
 * ✅ 追加（あなたの要望）
 * ✅ 行商人＋ラマの“足元の床ブロック”をレモンイエローにする
 * ✅ 乗っている瞬間だけ黄色（移動したら元に戻す＝塗り残りなし）
 * ✅ ステージ床（色付きガラス系）だけ対象（関係ない地形を塗らない）
 */
public class MovingSafetyZoneTask extends BukkitRunnable {

  private final JavaPlugin plugin;

  // ✅ 2tick周期の想定（runTaskTimerのperiodと合わせる）
  private static final int TASK_PERIOD_TICKS = 2;

  // ✅ 自前tick（Bukkit.getCurrentTick禁止なので代替）
  private long localTick = 0L;

  // ===== 見た目（レモンイエロー濃淡グラデ） =====
  // ✅ オレンジ系は完全廃止：透明感あるレモンイエローの濃淡のみ
  private final Particle.DustOptions lemonDustPale =
      new Particle.DustOptions(Color.fromRGB(255, 255, 225), 1.25f); // かなり淡い（透明感）
  private final Particle.DustOptions lemonDustLight =
      new Particle.DustOptions(Color.fromRGB(255, 255, 170), 1.45f); // 淡いレモン
  private final Particle.DustOptions lemonDustDeep =
      new Particle.DustOptions(Color.fromRGB(255, 238,  90), 1.65f); // 濃いレモン（でもオレンジ寄せない）

  // ===== 外の世界（冷たい影） =====
  private final Particle.DustOptions coldDust =
      new Particle.DustOptions(Color.fromRGB(80, 120, 180), 1.1f); // 寒色

  // ===== 探索範囲・セーフ範囲 =====
  private final double searchRange = 30.0;
  private final double safeRadius = 3.0;
  private final double safeRadiusSq = safeRadius * safeRadius;

  // ===== リング密度（軽量化ポイント） =====
  private final int ringPoints = 18;

  // ===== 残光（軌跡）設定 =====
  private final int trailLifetimeTicks = 60;      // 3秒 (20tps基準)
  private final double trailMinMove = 0.35;       // キャリアがこれ以上動いたら軌跡を追加
  private final int trailMaxPointsPerTrader = 60; // メモリ安全策

  // carrierUUID -> TrailPoints
  private final Map<UUID, Deque<TrailPoint>> trails = new HashMap<>();
  private final Map<UUID, Location> lastTraderLoc = new HashMap<>();

  // プレイヤー寒冷サウンドの鳴りすぎ防止
  private final Map<UUID, Integer> coldSoundCooldown = new HashMap<>();
  private final int coldSoundCooldownTicks = 40; // 2秒

  // ✅ クラック音の鳴りすぎ防止
  private final Map<UUID, Integer> crackSoundCooldown = new HashMap<>();
  private final int crackSoundCooldownTicks = 10; // 0.5秒くらい

  // ✅ 宝箱接近（緊張音）鳴りすぎ防止
  private final Map<UUID, Integer> tensionSoundCooldown = new HashMap<>();
  private final int tensionSoundCooldownTicks = 8; // 0.4秒くらい

  // ✅ 追加: 疑似屈折（視界揺れ）鳴りすぎ防止
  private final Map<UUID, Integer> refractionCooldown = new HashMap<>();
  private final int refractionCooldownTicks = 14; // 0.7秒くらい（連続で揺れすぎない）

  // ✅ 追加: 幾何学クラック（鳴りすぎ防止）
  private final Map<UUID, Integer> geoCrackCooldown = new HashMap<>();
  private final int geoCrackCooldownTicks = 6; // 0.3秒

  // ✅ クラック粒子用のBlockData（ガラス由来）
  private final BlockData glassCrackData;

  // ✅ 追加: 散りゆく光（ガラス破片）用
  private final ItemStack glassShardItem = new ItemStack(Material.GLASS_PANE);

  // ✅ 宝箱位置の供給（あなたのTreasureChestManagerに接続するための差し替え口）
  // 例：() -> treasureChestManager.getActiveTreasureLocations()
  private final TreasureProvider treasureProvider;

  // ✅ 宝箱座標キャッシュ（毎tick全探索しない）
  private List<Location> cachedTreasures = new ArrayList<>();
  private long nextTreasureCacheRefreshTick = 0L;
  private final int treasureCacheRefreshIntervalTicks = 20; // 1秒

  // ✅ 追加: NAUSEA/CONFUSION 両対応（コンパイル事故回避）
  private final PotionEffectType nauseaLikeEffectType = resolveNauseaEffectType();

  // ============================================================
  // ✅ 追加：足元床を「乗っている瞬間だけ」レモンにする仕組み
  //   - キャリアごとに「今乗ってる床」を覚える
  //   - 乗る床が変わったら「直前の床を元に戻す」
  //   - ステージ床（色付きガラス系）だけ対象
  //   - 複数キャリアが同じ床に乗る可能性に備えて参照カウント
  // ============================================================

  // carrierUUID -> 今黄色にしている床
  private final Map<UUID, BlockKey> carrierFootBlock = new HashMap<>();

  // 黄色化した床の「元のBlockData」を保存（復元用）
  private final Map<BlockKey, BlockData> originalFloorData = new HashMap<>();

  // 床が同時に何体に踏まれているか（0になったら復元）
  private final Map<BlockKey, Integer> floorRefCount = new HashMap<>();

  private final Set<BlockKey> steppedFloorsThisTick = new HashSet<>();// ✅ このtickで“踏まれている床”を記録（それ以外の黄色床は強制復元する保険）

  // ✅ 足元対象の床を「透明レモン」にする
  private static final Material LEMON_FLOOR = Material.YELLOW_STAINED_GLASS;

  // ✅ 足元判定のYオフセット（“床ブロック”）
  private static final int UNDER_FOOT_Y = -1;

  public MovingSafetyZoneTask(JavaPlugin plugin) {
    this(plugin, null);
  }

  /**
   * ✅ treasureProvider を渡すと「宝箱接近ピーク」が有効になる
   */
  public MovingSafetyZoneTask(JavaPlugin plugin, TreasureProvider treasureProvider) {
    this.plugin = plugin;
    this.treasureProvider = treasureProvider;

    // ガラスのクラック粒子（見た目の“脆さ”）
    // ※Minecraft側ではBLOCK_CRACKにBlockDataを渡す必要がある
    this.glassCrackData = Bukkit.createBlockData("minecraft:glass");
  }

  @Override
  public void run() {
    // ✅ 自前tick更新（2tick周期前提）
    localTick += TASK_PERIOD_TICKS;

    steppedFloorsThisTick.clear();// ✅ 今tickで踏まれている床キーをリセット

    // ✅ 同じtickで同じキャリア（商人/ラマ）を複数回処理しない
    Set<UUID> processedCarriers = new HashSet<>();

    // ✅ このtickで存在が確認できたキャリア
    Set<UUID> aliveCarriers = new HashSet<>();

    // ✅ そのtickで検出できたキャリアの中心座標（World.getEntity禁止なので保持する）
    List<Location> carrierCenters = new ArrayList<>();

    // ✅ 宝箱位置キャッシュ更新（軽量化）
    refreshTreasureCacheIfNeeded();

    // 1) キャリア（商人/ラマ）のリング＋軌跡登録
    //    ※プレイヤー視点の「近傍」から検出しているので、同一キャリアが複数回見える → UUIDで重複排除
    for (Player viewer : Bukkit.getOnlinePlayers()) {
      if (!viewer.isOnline()) continue;

      for (Entity entity : viewer.getNearbyEntities(searchRange, searchRange, searchRange)) {

        // ✅ 商人 or ラマ（隊商）両対応
        if (!(entity instanceof WanderingTrader) && !(entity instanceof TraderLlama)) continue;

        LivingEntity carrier = (LivingEntity) entity;
        UUID carrierId = carrier.getUniqueId();

        aliveCarriers.add(carrierId);

        // 重複防止
        if (!processedCarriers.add(carrierId)) continue;

        Location base = carrier.getLocation();
        Location center = base.clone().add(0, 0.2, 0);

        carrierCenters.add(center);

        // ✅ 動く光（リング）
        spawnAmberRingAt(base);

        // ✅ 残光（軌跡）ポイントの追加
        updateTrailAt(carrierId, base);

        // ✅ 追加：足元床を「乗っている瞬間だけ」レモンイエローに
        updateCarrierFootFloor(carrierId, base);
      }
    }

    // 2) 残光（軌跡）描画＆期限切れ掃除
    renderAndCleanupTrails(aliveCarriers);

    // ✅ 追加：検出できなかったキャリア（遠くへ行った/視界外になった等）の床を確実に復元（塗り残し防止）
    cleanupCarrierFootFloors(aliveCarriers);

    forceRestoreNotSteppedFloors(); //✅ 追加：今tickで踏まれていない黄色床を強制復元（増殖・塗り残し完全防止）

    // 3) プレイヤー側：近くにキャリア（安全）かどうかで世界を同期
    updatePlayersColdWorld(carrierCenters);

    // 4) クールダウン減衰
    tickCooldowns();
  }

  // -------------------------
  // ✅ レモン濃淡グラデ：点ごと＆tickで色がゆっくり揺れる
  // -------------------------
  private Particle.DustOptions pickLemonDust(int index) {
    // localTick は2tick刻みで進むので、見た目はゆっくり切り替わる
    long phase = (localTick / TASK_PERIOD_TICKS) / 6; // 6周期で変化（好みで調整OK）
    int m = (int) ((index + phase) % 3);
    if (m == 0) return lemonDustPale;
    if (m == 1) return lemonDustLight;
    return lemonDustDeep;
  }

  // -------------------------
  // 動く光：キャリアのリング（Location中心）
  // -------------------------
  private void spawnAmberRingAt(Location base) {
    World world = base.getWorld();
    if (world == null) return;

    Location center = base.clone().add(0, 0.2, 0);

    for (int i = 0; i < ringPoints; i++) {
      double angle = (2 * Math.PI) * i / ringPoints;

      double x = center.getX() + Math.cos(angle) * safeRadius;
      double z = center.getZ() + Math.sin(angle) * safeRadius;

      Location pLoc = new Location(world, x, center.getY(), z);

      // ✅ REDSTONEはDustOptionsをdataとして渡す必要がある（互換安全形）
      // ✅ オレンジ廃止 → レモンイエロー濃淡グラデ
      Particle.DustOptions dustA = pickLemonDust(i);
      world.spawnParticle(Particle.REDSTONE, pLoc, 1, 0, 0, 0, 0, dustA);

      // ✅ 透明感のある“濃淡”を強くするため、同地点にもう1層だけ重ねる（負荷軽）
      // ほんの少しだけオフセットして“グラデ感”を出す
      Particle.DustOptions dustB = pickLemonDust(i + 1);
      world.spawnParticle(Particle.REDSTONE, pLoc, 1, 0.02, 0.00, 0.02, 0, dustB);
    }

    // 温かい舞い上がりを少しだけ（希望の気配）
    // ※色を持たない白系粒子なので、オレンジ化しない
    world.spawnParticle(Particle.END_ROD, center, 1, 0.12, 0.03, 0.12, 0.0);
  }

  // -------------------------
  // ✅ 追加：足元床を「乗っている瞬間だけ」レモンにする
  // -------------------------
  private void updateCarrierFootFloor(UUID carrierId, Location carrierLoc) {
    if (carrierLoc == null) return;
    World w = carrierLoc.getWorld();
    if (w == null) return;

    Block under = carrierLoc.getBlock().getRelative(0, UNDER_FOOT_Y, 0);

    // ✅ ステージ床だけ対象（色付きガラス系以外は触らない）
    if (!isStageFloorBlock(under)) {
      // もし前回黄色にしていた床があるなら復元する（塗り残し防止）
      BlockKey prev = carrierFootBlock.get(carrierId);
      if (prev != null) {
        releaseFloorForCarrier(carrierId, prev);
      }
      return;
    }

    BlockKey nowKey = BlockKey.fromBlock(under);

    steppedFloorsThisTick.add(nowKey); // ✅ このtickで“踏まれている床”として記録

    // 前回と同じ床なら何もしない（余計なsetType回避）
    BlockKey prevKey = carrierFootBlock.get(carrierId);
    if (nowKey.equals(prevKey)) {
      // 念のため「黄色が剥がれていたら」戻す（他処理との競合対策）
      if (under.getType() != LEMON_FLOOR) {
        // 元データを保存しているはずなので、そのまま黄色にするだけ
        under.setType(LEMON_FLOOR, false);
      }
      return;
    }

    // ✅ 前の床を復元（参照カウント式）
    if (prevKey != null) {
      releaseFloorForCarrier(carrierId, prevKey);
    }

    // ✅ 新しい床を黄色にする（参照カウント式）
    acquireFloorForCarrier(carrierId, nowKey, under);
  }

  /**
   * ✅ “この床を踏む”を開始
   * - 参照カウント 0→1 の瞬間だけ元BlockDataを保存してから黄色化
   */
  private void acquireFloorForCarrier(UUID carrierId, BlockKey key, Block under) {
    int ref = floorRefCount.getOrDefault(key, 0);

    // 初めて誰かが踏むなら、元の床データを保存
    if (ref <= 0) {
      // cloneして保存（後で確実に復元するため）
      originalFloorData.put(key, under.getBlockData().clone());
      floorRefCount.put(key, 1);

      // 黄色に変更（透明レモン）
      under.setType(LEMON_FLOOR, false);
    } else {
      // 既に誰かが踏んでいる床 → 参照カウントだけ増やす（色は既に黄色のはず）
      floorRefCount.put(key, ref + 1);

      // 念のため色が違えば黄色にして統一
      if (under.getType() != LEMON_FLOOR) {
        under.setType(LEMON_FLOOR, false);
      }
    }

    carrierFootBlock.put(carrierId, key);
  }

  /**
   * ✅ “この床を踏む”を終了（移動した・検出されなくなった）
   * - 参照カウントが 0 になったら元BlockDataで完全復元
   */
  private void releaseFloorForCarrier(UUID carrierId, BlockKey key) {
    carrierFootBlock.remove(carrierId);

    int ref = floorRefCount.getOrDefault(key, 0);
    int next = ref - 1;

    if (next > 0) {
      floorRefCount.put(key, next);
      return;
    }

    // 0以下になったら復元して掃除
    floorRefCount.remove(key);

    BlockData original = originalFloorData.remove(key);
    if (original == null) return;

    World w = key.getWorld();
    if (w == null) return;

    Block b = w.getBlockAt(key.x, key.y, key.z);

    // ✅ 復元はBlockDataで確実に（元が何色のガラスでも戻る）
    b.setBlockData(original, false);
  }

  /**
   * ✅ このtickで“存在が確認できなかったキャリア”が踏んでいた床を復元
   * （プレイヤーから離れて検出されなくなった場合でも塗り残しが出ない）
   */
  private void cleanupCarrierFootFloors(Set<UUID> aliveCarriers) {
    // aliveCarriersにいないキャリアが「踏んでる扱い」なら復元する
    List<UUID> toCleanup = new ArrayList<>();
    for (UUID carrierId : carrierFootBlock.keySet()) {
      if (!aliveCarriers.contains(carrierId)) {
        toCleanup.add(carrierId);
      }
    }

    for (UUID carrierId : toCleanup) {
      BlockKey prev = carrierFootBlock.get(carrierId);
      if (prev != null) {
        releaseFloorForCarrier(carrierId, prev);
      }
    }
  }

  /**
   * ✅ “ステージ床だけ”を対象にする判定
   * - 色付きガラス系（_STAINED_GLASS）または GLASS のみ
   * - それ以外（草・土・石など）は絶対に触らない
   */
  private boolean isStageFloorBlock(Block b) {
    if (b == null) return false;

    Material type = b.getType();
    if (type == null) return false;

    // 色付きガラス床（透明感ある床）の想定
    String name = type.name();
    if (name.endsWith("_STAINED_GLASS")) return true;

    // もしステージ床に普通のガラスを使ってる場合にも対応
    if (type == Material.GLASS) return true;

    // 必要ならここに追加できる（例：TINTED_GLASS をステージ床に使うなら true にする）
    // if (type == Material.TINTED_GLASS) return true;

    return false;
  }

  /**
   * ✅ ブロック位置のキー（World+座標）
   * - Locationをそのままキーにすると誤差や参照で事故るので、必ず整数座標＋worldUUIDで固定
   */
  private static class BlockKey {
    final UUID worldId;
    final int x;
    final int y;
    final int z;

    private BlockKey(UUID worldId, int x, int y, int z) {
      this.worldId = worldId;
      this.x = x;
      this.y = y;
      this.z = z;
    }

    static BlockKey fromBlock(Block b) {
      World w = b.getWorld();
      UUID wid = (w != null) ? w.getUID() : new UUID(0L, 0L);
      return new BlockKey(wid, b.getX(), b.getY(), b.getZ());
    }

    World getWorld() {
      for (World w : Bukkit.getWorlds()) {
        if (w != null && w.getUID().equals(worldId)) return w;
      }
      return null;
    }

    @Override
    public boolean equals(Object o) {
      if (this == o) return true;
      if (!(o instanceof BlockKey)) return false;
      BlockKey k = (BlockKey) o;
      return x == k.x && y == k.y && z == k.z && worldId.equals(k.worldId);
    }

    @Override
    public int hashCode() {
      return Objects.hash(worldId, x, y, z);
    }
  }

  // -------------------------
  // 残光：軌跡ポイント追加（UUID＋Location）
  // -------------------------
  private void updateTrailAt(UUID id, Location nowLoc) {
    Location now = nowLoc.clone();

    Location last = lastTraderLoc.get(id);
    if (last == null) {
      lastTraderLoc.put(id, now);
      trails.putIfAbsent(id, new ArrayDeque<>());
      // 初回点は入れておく
      addTrailPoint(id, now);
      return;
    }

    // 移動距離が小さいなら追加しない（負荷軽減）
    if (last.getWorld() == now.getWorld()
        && last.distanceSquared(now) < (trailMinMove * trailMinMove)) {
      return;
    }

    lastTraderLoc.put(id, now);
    addTrailPoint(id, now);
  }

  private void addTrailPoint(UUID carrierId, Location loc) {
    Deque<TrailPoint> q = trails.computeIfAbsent(carrierId, k -> new ArrayDeque<>());

    long expireAt = localTick + trailLifetimeTicks;

    // 足元っぽく、やや低め
    Location point = loc.clone().add(0, 0.05, 0);

    q.addLast(new TrailPoint(point, expireAt));

    // 安全に最大数制限
    while (q.size() > trailMaxPointsPerTrader) {
      q.removeFirst();
    }
  }

  // -------------------------
  // 残光：描画＆期限切れ掃除
  // -------------------------
  private void renderAndCleanupTrails(Set<UUID> aliveCarriers) {
    long nowTick = localTick;

    // 消えたキャリアのデータ掃除
    trails.keySet().removeIf(id -> !aliveCarriers.contains(id));
    lastTraderLoc.keySet().removeIf(id -> !aliveCarriers.contains(id));

    for (UUID carrierId : aliveCarriers) {
      Deque<TrailPoint> q = trails.get(carrierId);
      if (q == null || q.isEmpty()) continue;

      // 期限切れ削除
      while (!q.isEmpty() && q.peekFirst().expireAtTick <= nowTick) {
        q.removeFirst();
      }
      if (q.isEmpty()) continue;

      // 残った軌跡を描画（古いほど薄くする）
      int index = 0;

      for (TrailPoint tp : q) {
        index++;

        Location p = tp.loc;
        World world = p.getWorld();
        if (world == null) continue;

        // 薄さ：古いほど少なく
        if (index % 2 == 0) {
          // ✅ オレンジ廃止 → レモン濃淡
          Particle.DustOptions dust = pickLemonDust(index);
          world.spawnParticle(Particle.REDSTONE, p, 1, 0, 0, 0, 0, dust);
        }

        // ふわっと散る“残り香”
        if (index % 6 == 0) {
          world.spawnParticle(Particle.END_ROD, p, 1, 0.03, 0.02, 0.03, 0.0);
        }
      }
    }
  }

  // -------------------------
  // プレイヤー：離れると世界が冷える + クラック同期 + 宝箱接近ピーク
  // -------------------------
  private void updatePlayersColdWorld(List<Location> carrierCenters) {
    boolean noCarriers = carrierCenters.isEmpty();

    for (Player p : Bukkit.getOnlinePlayers()) {
      if (!p.isOnline()) continue;

      boolean inSafe = false;

      if (!noCarriers) {
        Location pl = p.getLocation();

        // 最寄りのキャリア（商人/ラマ）中心が3m以内ならセーフ
        for (Location center : carrierCenters) {
          if (center == null) continue;
          if (center.getWorld() == null) continue;
          if (!center.getWorld().equals(pl.getWorld())) continue;

          if (pl.distanceSquared(center) <= safeRadiusSq) {
            inSafe = true;
            break;
          }
        }
      }

      // ✅ 宝箱接近係数（0.0〜1.0）: 近いほど1に近づく
      double treasureFactor = getTreasureProximityFactor(p);

      // ✅ 追加: 宝箱までの実距離（2m判定に使う）
      double nearestTreasureSq = getNearestTreasureDistanceSquared(p);
      boolean nearTreasure2m = (nearestTreasureSq >= 0.0) && (nearestTreasureSq <= 4.0);

      if (!inSafe) {
        // ✅ 世界が冷える：霧（寒色）＋冷たい音（低頻度）
        spawnColdFog(p);
        playColdSoundWithCooldown(p);

        // ✅ 外はクラックが増える
        // treasureFactor に応じて “ヘアライン→幾何学ピーク” に近づける
        spawnCracksAroundPlayer(p, treasureFactor);

        // ✅ 緊張音（宝箱が近いほど“刺さる”）
        playTensionSoundIfNeeded(p, treasureFactor);

        // ✅ 宝箱2m以内＝ガラス破片が放散（散りゆく光）
        if (nearTreasure2m) {
          spawnGlassShardDispersion(p, treasureFactor);
        }

        // ✅ 宝箱2m以内＝0.5秒だけ視界が微妙に揺れる（疑似屈折）
        if (nearTreasure2m) {
          applyRefractionWobble(p, treasureFactor);
        }

        // ✅ 宝箱2m以内＝幾何学クラック（数学的な模様）
        if (nearTreasure2m) {
          spawnGeometricCracksNearTreasure(p, treasureFactor);
        }

      } else {
        // ✅ セーフ内はクラックが鎮まる（最小）
        // それでも完全ゼロではなく“余白”としてほんの少し残す
        spawnSoftCracksInSafeZone(p);

        // ✅ セーフ内でも宝箱2mに入ったら「脆さの刺さり」は発生していい（温かさの中の危うさ）
        if (nearTreasure2m) {
          spawnGlassShardDispersion(p, treasureFactor);
          applyRefractionWobble(p, treasureFactor);
          spawnGeometricCracksNearTreasure(p, treasureFactor);
        }
      }
    }
  }

  // -------------------------
  // 冷え：霧
  // -------------------------
  private void spawnColdFog(Player p) {
    Location loc = p.getLocation().clone().add(0, 1.0, 0);
    World w = p.getWorld();

    // 寒い霧：足元ではなく、視界の周りに薄く
    w.spawnParticle(Particle.REDSTONE, loc, 2, 0.6, 0.3, 0.6, 0, coldDust);

    // 影の粒子：ソフトに
    w.spawnParticle(Particle.ASH, loc, 1, 0.4, 0.2, 0.4, 0.0);
  }

  // -------------------------
  // 冷え：音（低頻度）
  // -------------------------
  private void playColdSoundWithCooldown(Player p) {
    UUID id = p.getUniqueId();
    int cd = coldSoundCooldown.getOrDefault(id, 0);
    if (cd > 0) return;

    // 冷たい“荒野感”のワンショット
    p.playSound(p.getLocation(), Sound.BLOCK_AMETHYST_BLOCK_CHIME, 0.3f, 0.6f);

    coldSoundCooldown.put(id, coldSoundCooldownTicks);
  }

  // -------------------------
  // ✅ クラック：外（増える）
  // “ヘアライン→幾何学” を treasureFactor で段階演出
  // -------------------------
  private void spawnCracksAroundPlayer(Player p, double treasureFactor) {
    World w = p.getWorld();
    Location base = p.getLocation().clone();

    // treasureFactorが高いほど密度UP
    // 0.0: 2粒 / 1.0: 10粒くらい
    int count = 2 + (int) Math.round(8 * treasureFactor);

    // 範囲も少し増やす
    double radius = 0.5 + 1.0 * treasureFactor;

    for (int i = 0; i < count; i++) {
      double ox = (Math.random() - 0.5) * 2 * radius;
      double oz = (Math.random() - 0.5) * 2 * radius;

      Location loc = base.clone().add(ox, 0.05, oz);

      // “ガラスが軋む”視覚：BLOCK_CRACK（見た目はクラックの粒）
      w.spawnParticle(Particle.BLOCK_CRACK, loc, 2, 0.02, 0.02, 0.02, 0.0, glassCrackData);
    }

    // クラック音も同期（近いほどやや増えるが鳴りすぎない）
    playCrackSoundWithCooldown(p, treasureFactor);
  }

  private void playCrackSoundWithCooldown(Player p, double treasureFactor) {
    UUID id = p.getUniqueId();
    int cd = crackSoundCooldown.getOrDefault(id, 0);
    if (cd > 0) return;

    // treasureFactorに応じて少しだけ音量/ピッチ変化
    float vol = 0.05f + (float) (0.08f * treasureFactor);     // 0.05〜0.13
    float pitch = 0.8f + (float) (0.5f * treasureFactor);     // 0.8〜1.3

    // ガラスの緊張感
    p.playSound(p.getLocation(), Sound.BLOCK_GLASS_STEP, vol, pitch);

    crackSoundCooldown.put(id, crackSoundCooldownTicks);
  }

  // -------------------------
  // ✅ クラック：内（鎮まる）
  // “ゼロ”ではなく「余白」として薄く残す
  // -------------------------
  private void spawnSoftCracksInSafeZone(Player p) {
    World w = p.getWorld();
    Location base = p.getLocation().clone();

    // たまにだけ、ほんの少し
    if (Math.random() < 0.85) return;

    Location loc = base.clone().add((Math.random() - 0.5) * 0.4, 0.05, (Math.random() - 0.5) * 0.4);
    w.spawnParticle(Particle.BLOCK_CRACK, loc, 1, 0.01, 0.01, 0.01, 0.0, glassCrackData);
  }

  // -------------------------
  // ✅ 宝箱接近：緊張音（True Faith的な“迫ってくる圧”）
  // -------------------------
  private void playTensionSoundIfNeeded(Player p, double treasureFactor) {
    if (treasureFactor <= 0.0) return;

    UUID id = p.getUniqueId();
    int cd = tensionSoundCooldown.getOrDefault(id, 0);
    if (cd > 0) return;

    // 近いほど刺す：音量わずかUP / ピッチUP
    float vol = 0.03f + (float) (0.10f * treasureFactor);     // 0.03〜0.13
    float pitch = 0.7f + (float) (0.8f * treasureFactor);     // 0.7〜1.5

    // “ガラス床の不安”を音にする（控えめ）
    p.playSound(p.getLocation(), Sound.BLOCK_AMETHYST_CLUSTER_STEP, vol, pitch);

    tensionSoundCooldown.put(id, tensionSoundCooldownTicks);
  }

  // -------------------------
  // ✅ 宝箱接近係数（0〜1）
  // 1に近いほど「絶頂期（クラック幾何学ピーク）」へ
  // -------------------------
  private double getTreasureProximityFactor(Player p) {
    if (cachedTreasures.isEmpty()) return 0.0;

    Location pl = p.getLocation();
    World w = pl.getWorld();
    if (w == null) return 0.0;

    double minSq = Double.MAX_VALUE;

    for (Location t : cachedTreasures) {
      if (t == null) continue;
      if (t.getWorld() == null) continue;
      if (!t.getWorld().equals(w)) continue;

      double d = t.distanceSquared(pl);
      if (d < minSq) minSq = d;
    }

    if (minSq == Double.MAX_VALUE) return 0.0;

    // 近接判定距離（この中に入るとピークへ）
    // 例：20m → 0、 2m → 1 に近づく
    double maxDist = 20.0;
    double minDist = 2.0;

    double dist = Math.sqrt(minSq);

    if (dist >= maxDist) return 0.0;
    if (dist <= minDist) return 1.0;

    // 0..1へ正規化（近いほど1）
    double t = (maxDist - dist) / (maxDist - minDist);

    // “迫るほど加速する”カーブ（指数っぽい心理）
    return clamp01(Math.pow(t, 1.6));
  }

  private void refreshTreasureCacheIfNeeded() {
    if (treasureProvider == null) return;

    if (localTick < nextTreasureCacheRefreshTick) return;

    nextTreasureCacheRefreshTick = localTick + treasureCacheRefreshIntervalTicks;

    try {
      Collection<Location> locs = treasureProvider.getTreasureLocations();
      if (locs == null) {
        cachedTreasures = new ArrayList<>();
        return;
      }
      cachedTreasures = new ArrayList<>(locs);
    } catch (Exception ex) {
      // 失敗してもゲームを壊さない
      cachedTreasures = new ArrayList<>();
    }
  }

  private double clamp01(double v) {
    if (v < 0.0) return 0.0;
    if (v > 1.0) return 1.0;
    return v;
  }

  // -------------------------
  // ✅ 追加: 最寄り宝箱までの距離^2（2m判定用）
  // -------------------------
  private double getNearestTreasureDistanceSquared(Player p) {
    if (cachedTreasures.isEmpty()) return -1.0;

    Location pl = p.getLocation();
    World w = pl.getWorld();
    if (w == null) return -1.0;

    double minSq = Double.MAX_VALUE;

    for (Location t : cachedTreasures) {
      if (t == null) continue;
      if (t.getWorld() == null) continue;
      if (!t.getWorld().equals(w)) continue;

      double d = t.distanceSquared(pl);
      if (d < minSq) minSq = d;
    }

    if (minSq == Double.MAX_VALUE) return -1.0;
    return minSq;
  }

  // -------------------------
  // ✅ 追加: ガラス破片の放散（散りゆく光）
  // 宝箱2m以内で発生：粒が外へ逃げる＝“絶頂は留まらない”
  // -------------------------
  private void spawnGlassShardDispersion(Player p, double treasureFactor) {
    World w = p.getWorld();
    Location base = p.getLocation().clone().add(0, 0.15, 0);

    // 近いほど強い（ただし過剰にならない）
    int shards = 6 + (int) Math.round(10 * treasureFactor); // 6〜16

    // ✅ ITEM_CRACK：ガラス片が舞う（破片の“質感”）
    w.spawnParticle(
        Particle.ITEM_CRACK,
        base,
        shards,
        0.15, 0.08, 0.15,
        0.12,
        glassShardItem
    );

    // ✅ BLOCK_CRACK：ガラス床そのものがほどける
    w.spawnParticle(
        Particle.BLOCK_CRACK,
        base,
        6,
        0.12, 0.02, 0.12,
        0.10,
        glassCrackData
    );

    // ✅ “散りゆく光”のスパーク（控えめ）
    w.spawnParticle(
        Particle.FIREWORKS_SPARK,
        base,
        2,
        0.10, 0.06, 0.10,
        0.02
    );

    // ✅ 音も物理に寄せる（小さく）
    p.playSound(p.getLocation(), Sound.BLOCK_GLASS_BREAK, 0.05f, 1.6f);
  }

  // -------------------------
  // ✅ 追加: 疑似屈折（0.5秒だけ視界が微妙に揺れる）
  // ✅ NAUSEA/CONFUSION 両対応で安全に
  // -------------------------
  private void applyRefractionWobble(Player p, double treasureFactor) {
    UUID id = p.getUniqueId();
    int cd = refractionCooldown.getOrDefault(id, 0);
    if (cd > 0) return;

    // 近いほど発生率が上がる（常時揺れないように）
    double chance = 0.25 + 0.55 * treasureFactor; // 0.25〜0.80
    if (Math.random() > chance) return;

    // 0.5秒（10tick）
    int durationTicks = 10;

    PotionEffectType type = nauseaLikeEffectType;
    if (type == null) return; // もし何も取れなかったら安全に無視

    // amplifier 0（最弱）
    // particles=false, icon=false => “効果が付いた感”を見せずに揺れだけ出す
    PotionEffect wobble = new PotionEffect(
        type,
        durationTicks,
        0,
        true,
        false,
        false
    );

    p.addPotionEffect(wobble);

    // ✅ “屈折の刺さり”を音でも一瞬だけ
    float vol = 0.03f + (float) (0.06f * treasureFactor);   // 0.03〜0.09
    float pitch = 1.2f + (float) (0.6f * treasureFactor);   // 1.2〜1.8
    p.playSound(p.getLocation(), Sound.BLOCK_AMETHYST_BLOCK_RESONATE, vol, pitch);

    refractionCooldown.put(id, refractionCooldownTicks);
  }

  // -------------------------
  // ✅ 追加: NAUSEA/CONFUSION 自動解決
  // -------------------------
  private PotionEffectType resolveNauseaEffectType() {
    // 1.20+ は "NAUSEA"
    PotionEffectType t = PotionEffectType.getByName("NAUSEA");
    if (t != null) return t;

    // 古い環境は "CONFUSION"
    t = PotionEffectType.getByName("CONFUSION");
    return t;
  }

  // -------------------------
  // ✅ 追加: 幾何学クラック（数学模様）
  // ✅ 2重リング + 角度固定 + 放射ライン
  // -------------------------
  private void spawnGeometricCracksNearTreasure(Player p, double treasureFactor) {
    UUID id = p.getUniqueId();
    int cd = geoCrackCooldown.getOrDefault(id, 0);
    if (cd > 0) return;

    // treasureFactorが低いなら出さない（ピーク付近だけ出る）
    if (treasureFactor < 0.80) return;

    World w = p.getWorld();
    Location center = p.getLocation().clone().add(0, 0.05, 0);

    // ✅ localTickで角度切替（Bukkit.getCurrentTick禁止）
    int stepDeg = ((localTick / TASK_PERIOD_TICKS) % 2 == 0) ? 60 : 45;

    // 2重リング
    double innerR = 0.35 + 0.15 * treasureFactor;  // 0.35〜0.50
    double outerR = 0.95 + 0.35 * treasureFactor;  // 0.95〜1.30

    // 密度（近いほど増やす）
    int raySegments = 4 + (int) Math.round(4 * treasureFactor); // 4〜8

    // ✅ リング点生成（内側＋外側）
    for (int deg = 0; deg < 360; deg += stepDeg) {
      double rad = Math.toRadians(deg);

      // 内リング
      spawnCrackAtPolar(w, center, innerR, rad, 2);

      // 外リング
      spawnCrackAtPolar(w, center, outerR, rad, 3);

      // ✅ 放射状の割れ筋（方向性）
      for (int s = 1; s <= raySegments; s++) {
        double t = (double) s / (double) raySegments; // 0..1
        double r = innerR + (outerR - innerR) * t;

        // “割れ筋”は少しだけジグる（完全直線だと人工的すぎる）
        double jiggle = (Math.random() - 0.5) * 0.06;
        spawnCrackAtPolar(w, center, r + jiggle, rad, 1);
      }
    }

    // ✅ 角の“幾何学感”を強くする：補助角（45°の時だけ 22.5°追加）
    if (stepDeg == 45) {
      for (int deg = 22; deg < 360; deg += 45) {
        double rad = Math.toRadians(deg);
        spawnCrackAtPolar(w, center, outerR * 0.85, rad, 1);
      }
    }

    // ほんの一瞬の音（幾何学模様が現れる“刺さり”）
    float vol = 0.02f + (float) (0.06f * treasureFactor);
    float pitch = 1.0f + (float) (0.8f * treasureFactor);
    p.playSound(p.getLocation(), Sound.BLOCK_GLASS_HIT, vol, pitch);

    geoCrackCooldown.put(id, geoCrackCooldownTicks);
  }

  private void spawnCrackAtPolar(World w, Location center, double radius, double rad, int count) {
    double x = center.getX() + Math.cos(rad) * radius;
    double z = center.getZ() + Math.sin(rad) * radius;

    Location loc = new Location(w, x, center.getY(), z);

    // BLOCK_CRACK（ガラスのひび）
    w.spawnParticle(
        Particle.BLOCK_CRACK,
        loc,
        count,
        0.01, 0.01, 0.01,
        0.0,
        glassCrackData
    );
  }

  // -------------------------
  // クールダウン減衰
  // -------------------------
  private void tickCooldowns() {
    // このタスクが2tick周期なら2減らす（runTaskTimerのperiodが2tick前提）
    decayCooldownMap(coldSoundCooldown, TASK_PERIOD_TICKS);
    decayCooldownMap(crackSoundCooldown, TASK_PERIOD_TICKS);
    decayCooldownMap(tensionSoundCooldown, TASK_PERIOD_TICKS);

    // ✅ 追加
    decayCooldownMap(refractionCooldown, TASK_PERIOD_TICKS);
    decayCooldownMap(geoCrackCooldown, TASK_PERIOD_TICKS);
  }

  private void decayCooldownMap(Map<UUID, Integer> map, int dec) {
    Iterator<Map.Entry<UUID, Integer>> it = map.entrySet().iterator();
    while (it.hasNext()) {
      Map.Entry<UUID, Integer> e = it.next();
      int v = e.getValue() - dec;
      if (v <= 0) it.remove();
      else e.setValue(v);
    }
  }

  // -------------------------
  // TrailPoint（残光ポイント）
  // -------------------------
  private static class TrailPoint {
    final Location loc;
    final long expireAtTick;

    TrailPoint(Location loc, long expireAtTick) {
      this.loc = loc;
      this.expireAtTick = expireAtTick;
    }
  }

  // -------------------------
  // ✅ 宝箱ロケーション供給インターフェース
  // TreasureChestManagerと繋ぐための差し替え口
  // -------------------------
  public interface TreasureProvider {
    Collection<Location> getTreasureLocations();
  }

  // ✅ Stop時に床を完全復元（残骸ゼロ）
  public void restoreAllFloors() {
    try {
      java.util.Map<BlockKey, BlockData> copy = new java.util.HashMap<>(originalFloorData);
      for (java.util.Map.Entry<BlockKey, BlockData> e : copy.entrySet()) {
        BlockKey key = e.getKey();
        BlockData data = e.getValue();
        if (key == null || data == null) continue;

        try {
          // --- BlockKey から (world,x,y,z) を reflection で取得（フィールド名差に耐える） ---
          java.util.UUID wid = null;
          Integer x = null, y = null, z = null;

          for (java.lang.reflect.Field f : key.getClass().getDeclaredFields()) {
            f.setAccessible(true);
            Object v = f.get(key);

            if (v instanceof java.util.UUID && wid == null) wid = (java.util.UUID) v;
            if (v instanceof Integer) {
              String n = f.getName().toLowerCase();
              if (x == null && (n.equals("x") || n.endsWith("x"))) x = (Integer) v;
              else if (y == null && (n.equals("y") || n.endsWith("y"))) y = (Integer) v;
              else if (z == null && (n.equals("z") || n.endsWith("z"))) z = (Integer) v;
            }
          }

          // フィールド名が想定と違う場合の保険：最初の3つのintを x,y,z とみなす
          if (x == null || y == null || z == null) {
            java.util.List<Integer> ints = new java.util.ArrayList<>();
            for (java.lang.reflect.Field f : key.getClass().getDeclaredFields()) {
              f.setAccessible(true);
              Object v = f.get(key);
              if (v instanceof Integer) ints.add((Integer) v);
            }
            if (ints.size() >= 3) {
              if (x == null) x = ints.get(0);
              if (y == null) y = ints.get(1);
              if (z == null) z = ints.get(2);
            }
          }

          if (wid == null || x == null || y == null || z == null) continue;

          World w = Bukkit.getWorld(wid);
          if (w == null) continue;

          Block b = w.getBlockAt(x, y, z);
          if (b == null) continue;

          b.setBlockData(data, false);
        } catch (Throwable ignored) {}
      }
    } catch (Throwable ignored) {
    } finally {
      originalFloorData.clear();
    }
  }

  @Override
  public synchronized void cancel() throws IllegalStateException {
    try { restoreAllFloors(); } catch (Throwable ignored) {}
    super.cancel();
  }

}